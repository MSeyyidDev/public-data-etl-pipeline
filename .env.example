# Optional configuration overrides for the ETL pipeline.
# Copy this file to `.env` and adjust as needed.

# Where to write SQLite DB and snapshots
ETL_OUTPUT_DIR=output
ETL_DB_FILENAME=etl.db

# Reproducibility
ETL_RANDOM_SEED=42

# Synthetic data sizing
ETL_WEATHER_CITIES=5
ETL_WEATHER_DAYS=365
ETL_TRAFFIC_SENSORS=20
ETL_TRAFFIC_DAYS=90
ETL_SALES_PRODUCTS=50
ETL_SALES_DAYS=365
ETL_SALES_CUSTOMERS=1000
